# worker app env example
# Source: templates/workers/statefulsets.yaml

# From timezone-config ConfigMap (shared chart setting)
TZ=Europe/Prague

# Injected by chart for per-pod identity and callback wiring
POD_NAME="worker-curator-0"
WORKER_BASE_URL="http://$(POD_NAME).worker-curator.default.svc.cluster.local:8080/worker/api/"
WORKER_ID="$(POD_NAME)"
WORKER_LOOP_SLEEP_SECS="10"
WORKER_LOOP_PRINT_SECS="30"
MANAGER_BASE_URL="http://process-manager.default.svc.cluster.local:8080/process/api/"

# Present when workerGroups[].profilesSubset is set
PROFILES_SUBSET="import,new_indexer_index_object"

# From workerGroups[].env / workerGroups[].shadowEnv
# Example of user-provided non-CATALINA key:
TOMCAT_PASSWORD="changeme"

# Injected unless explicitly set in worker env map
HAZELCAST_SERVER_ADDRESSES="hazelcast.default.svc.cluster.local:5701"

# Assembled by chart helpers from worker group values and observability/javaagent settings
CATALINA_OPTS="-Xms512M -Xmx2G"
