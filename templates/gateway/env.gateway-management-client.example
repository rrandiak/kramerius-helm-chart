# gateway-management-client app env example
# Source: templates/gateway/deployment-management-client.yaml

PYTHONPATH="/app"
TZ="Europe/Prague"

# Set when gateway.managementApi.secret is configured
MANAGEMENT_API_SECRET="replace-with-secret"

# Set when gateway.managementClient.slack.signingSecret is configured
SLACK_SIGNING_SECRET="replace-with-secret"

# Optional override from gateway.managementClient.kraemeriusActionsUrl
KRAMERIUS_ACTIONS_URL="http://kramerius-public:8080/search/api/client/v7.0/user/actions?pid=uuid:1"

# Optional override from gateway.managementClient.browserRoot
GATEWAY_BROWSER_ROOT="/gateway"
