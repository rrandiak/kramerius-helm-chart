# kramerius-public app env example
# Source: templates/kramerius-public/statefulset.yaml

# From timezone-config ConfigMap (shared chart setting)
TZ=Europe/Prague

# From krameriusPublic.env / krameriusPublic.shadowEnv
TOMCAT_PASSWORD="changeme"

# Injected when not explicitly provided in krameriusPublic.env
HAZELCAST_SERVER_ADDRESSES="hazelcast.default.svc.cluster.local:5701"
PROCESS_MANAGER_URL="http://process-manager.default.svc.cluster.local:8080/process/api/"

# Assembled by chart helpers from krameriusPublic.* and observability/javaagent settings
CATALINA_OPTS="-Xms4g -Xmx8g"

# Injected by helper for log routing / pod identity
KRAMERIUS_POD_NAME="kramerius-public-0"
