# process-manager app env example
# Source: templates/process-manager/statefulset.yaml

# From timezone-config ConfigMap (shared chart setting)
TZ=Europe/Prague

# From processManager.env / processManager.shadowEnv
# (JAVA_OPTS value is assembled by chart helpers)
JAVA_OPTS="-Xms512M -Xmx2G"

# Injected by chart from databases.process (not taken from processManager.env)
JDBC_URL="jdbc:postgresql://postgres-process:5432/process"
JDBC_USERNAME="process_user"
JDBC_PASSWORD="<from-secret>"

# Injected by helper for log routing / pod identity
KRAMERIUS_POD_NAME="process-manager-0"
