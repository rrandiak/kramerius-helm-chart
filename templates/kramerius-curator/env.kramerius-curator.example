# kramerius-curator app env example
# Source: templates/kramerius-curator/statefulset.yaml

# From timezone-config ConfigMap (shared chart setting)
TZ=Europe/Prague

# From krameriusCurator.env / krameriusCurator.shadowEnv
TOMCAT_PASSWORD="changeme"

# Injected when not explicitly provided in krameriusCurator.env
HAZELCAST_SERVER_ADDRESSES="hazelcast.default.svc.cluster.local:5701"
PROCESS_MANAGER_URL="http://process-manager.default.svc.cluster.local:8080/process/api/"

# Assembled by chart helpers from krameriusCurator.* and observability/javaagent settings
CATALINA_OPTS="-Xms4g -Xmx8g"

# Injected by helper for log routing / pod identity
KRAMERIUS_POD_NAME="kramerius-curator-0"
